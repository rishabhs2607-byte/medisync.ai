rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    
    // Checks if the request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Checks if the authenticated user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Gets the current user's profile data from Firestore
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Checks if the user has a specific role
    function hasRole(role) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == role;
    }

    // Checks if the user is an approved clinician/entity
    function isApproved() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().status == 'approved';
    }

    // Checks if the user is an admin
    function isAdmin() {
      return hasRole('admin');
    }

    // Checks if the user is a doctor
    function isDoctor() {
      return hasRole('doctor');
    }

    // Checks if the user is a hospital user
    function isHospital() {
      return hasRole('hospital');
    }

    // ==========================================
    // COLLECTION-SPECIFIC RULES
    // ==========================================

    // 1. Users Profile Collection
    match /users/{userId} {
      // Any authenticated user can view other users' profile structures (e.g., patients viewing doctors, doctors viewing patients)
      allow read: if isAuthenticated();
      
      // Users can only create their own profile during registration
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can update their own profile (e.g., update availability, details), or admins can update everything (e.g., approving doctor license)
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }

    // 2. Patient Clinical Records (including vitals, allergies, family members, reports)
    match /patients/{patientId} {
      // Patients can read/write their own clinical file.
      // Approved doctors, hospital users, and admins can view/write patient records.
      allow read: if isOwner(patientId) || (isApproved() && (isDoctor() || isHospital() || isAdmin()));
      allow write: if isOwner(patientId) || (isApproved() && (isDoctor() || isHospital() || isAdmin()));
      
      // Sub-collections under patients (e.g., patient reports, telemetry history)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(patientId) || (isApproved() && (isDoctor() || isHospital() || isAdmin()));
      }
    }

    // 3. Appointments
    match /appointments/{appointmentId} {
      // Authenticated users can read appointments if they are the patient or doctor in it, or are hospital/admin
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId || 
        (isApproved() && (isHospital() || isAdmin()))
      );
      
      // Patients can schedule, and doctors/hospitals/admins can schedule/modify appointments
      allow create: if isAuthenticated() && (
        request.resource.data.patientId == request.auth.uid || 
        (isApproved() && (isDoctor() || isHospital() || isAdmin()))
      );
      
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId || 
        (isApproved() && (isHospital() || isAdmin()))
      );
      
      allow delete: if isAdmin() || (isApproved() && isHospital());
    }

    // 4. Clinical Prescriptions
    match /prescriptions/{prescriptionId} {
      // Patients can read their own prescriptions. Doctors, hospitals, and admins can read all.
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        (isApproved() && (isDoctor() || isHospital() || isAdmin()))
      );
      
      // Only approved doctors and admins can write/create prescriptions
      allow create, update: if isAuthenticated() && (
        (isApproved() && isDoctor() && request.resource.data.doctorId == request.auth.uid) || 
        isAdmin()
      );
      
      // Only admins can delete prescriptions
      allow delete: if isAdmin();
    }

    // 5. Emergency Alerts
    match /alerts/{alertId} {
      // Anyone authenticated can read/write alerts (so devices, patients, and doctors can generate alerts)
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        (isApproved() && (isDoctor() || isHospital() || isAdmin()))
      );
      
      // Any authenticated user/device can trigger or resolve an alert for themselves, and clinicians can manage them
      allow create, update: if isAuthenticated();
      
      // Only admins can delete alerts
      allow delete: if isAdmin();
    }

    // 6. Active Consultation Sessions (Telemedicine Room Recovery & Chats)
    match /sessions/{sessionId} {
      // Patients and doctors actively assigned to the session can read and write
      allow read, write: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId ||
        isAdmin()
      );
      
      // Nested messages, WebRTC signaling nodes, and chat sub-collections
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.patientId == request.auth.uid ||
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.doctorId == request.auth.uid ||
          isAdmin()
        );
      }
    }
  }
}
